---
import { films } from '../i18n.js';
const { t } = Astro.props;
---
<header class="site-header">
  <div class="container">
    <a class="wordmark" href={t.dir} translate="no">
      {t.brand.main}
      <span>{t.brand.sub}</span>
    </a>
    <nav class="nav" aria-label="Principal">
      <div class="nav-links">
        <a href="#peliculas">{t.nav.films}</a>
        <a href="#historia">{t.nav.story}</a>
        <a href="#comparte">{t.nav.share}</a>
        <a href="#gratitud">{t.nav.gratitude}</a>
        <a href="#regalo">{t.nav.gift}</a>
        <a href="#tienda">{t.nav.shop}</a>
      </div>
      <a class="lang-toggle" href={t.otherHref}>{t.otherLabel}</a>
    </nav>
  </div>
</header>

<main>
  <!-- HERO -->
  <section class="hero">
    <div class="orb orb-1" aria-hidden="true"></div>
    <div class="orb orb-2" aria-hidden="true"></div>
    <div class="orb orb-3" aria-hidden="true"></div>
    <div class="hero-inner" data-parallax="0.12">
      <p class="brand">{t.hero.brand}</p>
      <h1>{t.hero.title}</h1>
      <p class="tagline">{t.hero.tagline}</p>
      <p class="sub">{t.hero.sub}</p>
      <div class="hero-cta">
        <a class="btn btn-primary" href="#regalo">{t.hero.ctaPrimary}</a>
        <a class="btn btn-ghost" href="#peliculas">{t.hero.ctaSecondary}</a>
      </div>
    </div>
    <div class="scroll-hint">scroll</div>
  </section>

  <!-- FILMS -->
  <section id="peliculas" class="films">
    <div class="container">
      <p class="eyebrow reveal">{t.hero.title}</p>
      <h2 class="section-title reveal">{t.films.heading}</h2>
      <p class="intro reveal">{t.films.intro}</p>
      <div class="film-grid">
        {films.map((f) => (
          <a class="film-card reveal" href={f.youtube || '#'} aria-label={t.films.titles[f.id]}>
            <span class="num">{String(f.id).padStart(2, '0')}</span>
            <span class="badge">{t.films.comingSoon}</span>
            <h3>{t.films.titles[f.id]}</h3>
            <p class="ded">{t.films.dedications[f.id]}</p>
          </a>
        ))}
      </div>
    </div>
  </section>

  <!-- EPIGRAPH -->
  <section class="epigraph">
    <div class="container">
      <p class="epigraph-line reveal">{t.epigraph.a}</p>
      <span class="epigraph-rule reveal" aria-hidden="true"></span>
      <p class="epigraph-line epigraph-turn reveal">{t.epigraph.b}</p>
    </div>
  </section>

  <!-- STORY -->
  <section id="historia" class="story">
    <div class="container story-wrap">
      <header class="story-head reveal">
        <p class="eyebrow">{t.hero.title}</p>
        <h2 class="section-title">{t.story.heading}</h2>
      </header>
      <figure class="story-photo reveal">
        <img src="/images/story-madre.webp" width="780" height="1398" alt={t.story.photoAlt} loading="lazy" decoding="async" />
      </figure>
      <div class="story-body">
        {t.story.blocks.map((b) =>
          b.type === 'quote' ? (
            <blockquote class="story-quote reveal">{b.text}</blockquote>
          ) : b.type === 'em' ? (
            <p class="story-em reveal">{b.text}</p>
          ) : b.type === 'closing' ? (
            <p class="story-closing reveal">{b.text}</p>
          ) : (
            <p class="reveal">{b.text}</p>
          )
        )}
        <p class="signature reveal">{t.story.signoff}<br /><span>{t.story.name}</span></p>
      </div>
    </div>
  </section>

  <!-- SHARE YOUR STORY -->
  <section id="comparte" class="share">
    <div class="container">
      <h2 class="section-title reveal">{t.share.heading}</h2>
      <p class="share-sub reveal">{t.share.sub}</p>
      <!-- Wired to GoHighLevel after PIT token is set (Netlify env). Placeholder for now. -->
      <form class="share-form reveal" name="story" data-ghl="story">
        <input type="text" name="name" placeholder={t.share.namePlaceholder} aria-label={t.share.namePlaceholder} required />
        <input type="email" name="email" placeholder={t.share.emailPlaceholder} aria-label={t.share.emailPlaceholder} required />
        <textarea name="story" rows="5" placeholder={t.share.storyPlaceholder} aria-label={t.share.storyPlaceholder} required></textarea>
        <button class="btn btn-primary" type="submit">{t.share.button}</button>
      </form>
      <p class="share-privacy reveal">{t.share.privacy}</p>
    </div>
  </section>

  <!-- GRATITUDE -->
  <section id="gratitud" class="gratitude">
    <div class="container">
      <p class="eyebrow reveal">{t.gratitude.eyebrow}</p>
      <h2 class="section-title reveal">{t.gratitude.heading}</h2>
      <p class="intro reveal">{t.gratitude.intro}</p>
      <ul class="grat-list">
        {t.gratitude.practices.map((p) => (
          <li class="grat-item reveal">
            <h3>{p.t}</h3>
            <p>{p.d}</p>
          </li>
        ))}
      </ul>
      <p class="grat-close reveal">{t.gratitude.close}</p>
      <p class="grat-soon reveal">{t.gratitude.soon} <a href="#regalo">{t.gratitude.giftLink}</a></p>
      <div class="grat-page-cta reveal">
        <a class="btn btn-ghost" href={t.lang === 'es' ? '/gratitud' : '/en/gratitude'}>{t.gratitude.pageLink}</a>
      </div>
      <p class="grat-disclaimer reveal">{t.gratitude.disclaimer}</p>
    </div>
  </section>

  <!-- GIFT / EMAIL CAPTURE -->
  <section id="regalo" class="gift">
    <div class="container">
      <h2 class="section-title reveal">{t.gift.heading}</h2>
      <p class="sub reveal">{t.gift.sub}</p>
      <!-- Wired to GoHighLevel after PIT token is set (Netlify env). Placeholder for now. -->
      <form class="reveal" name="signup" data-ghl="gift">
        <input type="email" name="email" placeholder={t.gift.placeholder} required aria-label={t.gift.placeholder} />
        <button class="btn btn-primary" type="submit">{t.gift.button}</button>
      </form>
      <p class="privacy reveal">{t.gift.privacy}</p>
    </div>
  </section>

  <!-- SHOP -->
  <section id="tienda" class="shop">
    <div class="container">
      <p class="eyebrow reveal">{t.shop.heading}</p>
      <h2 class="section-title reveal">{t.shop.heading}</h2>
      <p class="intro reveal">{t.shop.intro}</p>
      <div class="shop-actions reveal">
        <a class="btn btn-primary" href={t.lang === 'es' ? '/cancion-personalizada' : '/en/custom-song'}>{t.shop.customLink}</a>
        <a class="btn btn-vino" href="https://www.etsy.com/shop/GreciaGroup" target="_blank" rel="noopener">{t.shop.etsy}</a>
      </div>
      <small class="soon reveal">{t.shop.soon}</small>
    </div>
  </section>
</main>

<footer class="site-footer">
  <div class="container">
    <p class="fbrand" translate="no">{t.brand.main}</p>
    <p class="fsub" translate="no">{t.brand.sub}</p>
    <div class="social">
      <a href="https://www.youtube.com/@TenderHeartRhythms" target="_blank" rel="noopener">YouTube</a>
      <a href="https://www.instagram.com/tenderheartrhythms" target="_blank" rel="noopener">Instagram</a>
      <a href="https://www.tiktok.com/@tenderheart.rhythms" target="_blank" rel="noopener">TikTok</a>
      <a href="https://www.pinterest.com/greciagroup" target="_blank" rel="noopener">Pinterest</a>
      <a href="https://www.etsy.com/shop/GreciaGroup" target="_blank" rel="noopener">Etsy</a>
    </div>
    <small>&copy; {new Date().getFullYear()} {t.footer.brand}. {t.footer.rights}</small>
    <small class="flegal">{t.footer.legal}</small>
  </div>
</footer>

<style>
  .gratitude { padding: clamp(3rem, 7vw, 5.5rem) 0; }
  .grat-list {
    list-style: none; margin: 2.4rem 0 0; padding: 0;
    display: grid; gap: 1.1rem;
    grid-template-columns: repeat(auto-fit, minmax(250px, 1fr));
  }
  .grat-item {
    position: relative; overflow: hidden;
    background: #FFFDF8; border: 1px solid #E7DDCA; border-radius: 18px;
    padding: 1.5rem 1.5rem 1.55rem;
    box-shadow: 0 1px 2px rgba(59,55,47,.05), 0 12px 30px rgba(59,55,47,.07);
    transition: transform .3s ease, box-shadow .3s ease;
  }
  .grat-item::before {
    content: ""; position: absolute; top: 0; left: 0; right: 0; height: 4px;
    background: #7C9885;
  }
  .grat-item:nth-child(2)::before { background: #C29B54; }
  .grat-item:nth-child(3)::before { background: #CE8A6A; }
  .grat-item:nth-child(4)::before { background: #7C3A44; }
  .grat-item:nth-child(5)::before { background: #5F7D6A; }
  .grat-item:hover { transform: translateY(-4px); box-shadow: 0 2px 4px rgba(59,55,47,.06), 0 20px 40px rgba(59,55,47,.1); }
  .grat-item h3 {
    font-family: 'Cormorant Garamond', Georgia, serif;
    font-size: 1.38rem; font-weight: 600; line-height: 1.15;
    margin: .3rem 0 .5rem; color: #5F7D6A; text-wrap: balance;
  }
  .grat-item p { margin: 0; color: #6f6a5e; font-size: .97rem; line-height: 1.62; }
  .grat-close {
    position: relative;
    font-family: 'Cormorant Garamond', Georgia, serif;
    font-size: clamp(1.45rem, 3.2vw, 1.85rem); font-style: italic;
    line-height: 1.35; text-align: center; text-wrap: balance;
    max-width: 46ch; margin: 3rem auto 0; padding-top: 2rem; color: #3B372F;
  }
  .grat-close::before {
    content: ""; position: absolute; top: 0; left: 50%; transform: translateX(-50%);
    width: 60px; height: 3px; border-radius: 2px; background: #C29B54;
  }
  .grat-soon {
    text-align: center; margin: 1.8rem auto 0; color: #7c766a; font-size: .96rem;
    background: rgba(124,152,133,.09); border: 1px solid rgba(124,152,133,.22);
    border-radius: 999px; padding: .7rem 1.5rem; width: fit-content; max-width: 100%;
  }
  .grat-soon a { color: #C29B54; font-weight: 700; text-decoration: none; border-bottom: 1px solid rgba(194,155,84,.45); }
  .grat-soon a:hover { border-bottom-color: #C29B54; }
  .grat-page-cta { text-align: center; margin-top: 1.6rem; }
  .grat-disclaimer { text-align: center; max-width: 62ch; margin: 1.8rem auto 0; font-size: .82rem; font-style: italic; color: #8a8478; }
  @media (prefers-reduced-motion: reduce) { .grat-item { transition: none; } .grat-item:hover { transform: none; } }
</style>
