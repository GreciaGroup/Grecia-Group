# Example env file — copy to .env for local dev (never commit the real .env).
# In production these live in Netlify -> Site settings -> Environment variables.
# Claude references these by NAME and never needs to see the real values.

# GoHighLevel private integration token (used only inside serverless functions)
GHL_PIT_TOKEN=

# GoHighLevel location / sub-account id
GHL_LOCATION_ID=
